# API 2 Cursor 环境变量配置

# 服务端口
PORT=28473

# 监听地址：本机直接跑用 127.0.0.1 便于前置 Nginx/Caddy 反代；Docker Compose 内会自动改为 0.0.0.0
LISTEN_ADDR=127.0.0.1

# 管理员令牌 (用于管理面板登录)
ADMIN_TOKEN=your-admin-token-here

# 数据库路径 (SQLite)
DB_PATH=data/api2cursor.db

# 数据目录
DATA_DIR=data

# 调试模式: off / simple / verbose
DEBUG_MODE=off
